#include <stdio.h>

int main() {
    int r1, c1, r2, c2;
    printf("Enter rows and columns for the first matrix: ");
    scanf("%d %d", &r1, &c1);
    printf("Enter rows and columns for the second matrix: ");
    scanf("%d %d", &r2, &c2);
    if (c1 != r2) {
        printf("Error! Matrix multiplication is not possible.\n");
        printf("Columns of the first matrix (%d) must equal rows of the second matrix (%d).\n", c1, r2);
        return 1;
    }
    int mat1[r1][c1];
    int mat2[r2][c2];
    int prod[r1][c2];
    printf("\nEnter elements for the first matrix:\n");
    for (int i = 0; i < r1; i++) {
        for (int j = 0; j < c1; j++) {
            printf("Element mat1[%d][%d]: ", i, j);
            scanf("%d", &mat1[i][j]);
        }
    }
    printf("\nEnter elements for the second matrix:\n");
    for (int i = 0; i < r2; i++) {
        for (int j = 0; j < c2; j++) {
            printf("Element mat2[%d][%d]: ", i, j);
            scanf("%d", &mat2[i][j]);
        }
    }
    for (int i = 0; i < r1; i++) {
        for (int j = 0; j < c2; j++) {
            prod[i][j] = 0; 
            for (int k = 0; k < c1; k++) {
                prod[i][j] += mat1[i][k] * mat2[k][j];
            }
        }
    }
    printf("\nResultant Multiplied Matrix:\n");
    for (int i = 0; i < r1; i++) {
        for (int j = 0; j < c2; j++) {
            printf("%d\t", prod[i][j]);
        }
        printf("\n");
    }

    return 0;
}
