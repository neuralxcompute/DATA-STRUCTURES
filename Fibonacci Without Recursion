#include <stdio.h>
int main() {
    int terms, i;
    long long t1 = 0, t2 = 1, nextTerm;

    printf("Enter the number of terms: ");
    if (scanf("%d", &terms) != 1 || terms <= 0) {
        printf("Please enter a valid positive integer.\n");
        return 1;
    }
    printf("Fibonacci Series: ");
    for (i = 1; i <= terms; ++i) {
        printf("%lld", t1);
        if (i < terms) {
            printf(", ");
        }
        nextTerm = t1 + t2;
        t1 = t2;
        t2 = nextTerm;
    }
    printf("\n");
    return 0;
}
